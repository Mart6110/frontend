# API Configuration
# Copy this file to .env.local for local development or .env.production for production

# Base URL for the API
# Local Development: /api/v1 (proxied through Vite dev server to localhost:8080)
# Production: https://dunepower-api.acceptable.pro/api/v1
# Dev against Production: https://dunepower-api.acceptable.pro/api/v1
VITE_API_BASE_URL=/api/v1
