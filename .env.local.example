# Local Override Environment
# Copy this file to .env.local to override development settings
# .env.local is gitignored and takes precedence over .env.development

# In development, always use /api/v1 (relative URL)
# The Vite proxy will forward requests to the configured backend
VITE_API_BASE_URL=/api/v1

# Example: Proxy to production backend (avoids CORS)
# VITE_PROXY_TARGET=https://dunepower-api.acceptable.pro

# Example: Proxy to custom backend
# VITE_PROXY_TARGET=http://192.168.1.100:8080
