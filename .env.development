# Development Environment
# This file is used when running `npm run dev`

# API Base URL - Always use relative URL in development
# Vite dev server will proxy /api/v1 to the backend
VITE_API_BASE_URL=/api/v1

# Proxy Target - Backend to proxy to (optional, defaults to localhost:8080)
# Local: http://localhost:8080
# Production: https://dunepower-api.acceptable.pro
# VITE_PROXY_TARGET=http://localhost:8080
